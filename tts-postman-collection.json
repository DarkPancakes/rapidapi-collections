{
  "info": {
    "name": "Text-to-Speech API",
    "description": "High-quality text-to-speech with 400+ voices in 100+ languages. Word-level timestamps, adjustable speed and pitch.\n\nGet your API key at: https://rapidapi.com/louismichalot/api/text-to-speech-api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://text-to-speech-api.p.rapidapi.com"
    },
    {
      "key": "rapidApiKey",
      "value": "YOUR_RAPIDAPI_KEY"
    },
    {
      "key": "rapidApiHost",
      "value": "text-to-speech-api.p.rapidapi.com"
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "X-RapidAPI-Key" },
      { "key": "value", "value": "{{rapidApiKey}}" },
      { "key": "in", "value": "header" }
    ]
  },
  "item": [
    {
      "name": "Free Tier",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/health",
            "header": [
              { "key": "X-RapidAPI-Key", "value": "{{rapidApiKey}}" },
              { "key": "X-RapidAPI-Host", "value": "{{rapidApiHost}}" }
            ],
            "description": "Check API status and available voice count."
          }
        },
        {
          "name": "List All Voices",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/voices",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "voices"],
              "query": [
                { "key": "language", "value": "en", "description": "Filter by language code (e.g. en, fr, es, pt)", "disabled": true }
              ]
            },
            "header": [
              { "key": "X-RapidAPI-Key", "value": "{{rapidApiKey}}" },
              { "key": "X-RapidAPI-Host", "value": "{{rapidApiHost}}" }
            ],
            "description": "List all 400+ available TTS voices. Optionally filter by language code."
          }
        },
        {
          "name": "Text to Speech",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/v1/tts",
            "header": [
              { "key": "X-RapidAPI-Key", "value": "{{rapidApiKey}}" },
              { "key": "X-RapidAPI-Host", "value": "{{rapidApiHost}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Hello world! This is a test of the text to speech API.\",\n  \"voice\": \"en-US-AriaNeural\",\n  \"rate\": \"+0%\",\n  \"pitch\": \"+0Hz\",\n  \"format\": \"mp3\"\n}"
            },
            "description": "Convert text to speech audio. Returns binary MP3 or WAV. Free tier: max 1000 chars."
          }
        }
      ]
    },
    {
      "name": "Basic Tier",
      "item": [
        {
          "name": "TTS with Timestamps",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/v1/tts/timestamps",
            "header": [
              { "key": "X-RapidAPI-Key", "value": "{{rapidApiKey}}" },
              { "key": "X-RapidAPI-Host", "value": "{{rapidApiHost}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Five amazing facts you probably didn't know about space.\",\n  \"voice\": \"en-US-GuyNeural\",\n  \"rate\": \"+0%\",\n  \"pitch\": \"+0Hz\",\n  \"format\": \"mp3\"\n}"
            },
            "description": "Convert text to speech with word-level timestamps. Returns audio as base64 + array of word boundaries with offset/duration in ms. Requires Basic tier."
          }
        }
      ]
    }
  ]
}
